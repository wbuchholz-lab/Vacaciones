rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    //  APP ACTUAL (calendario único en /participants)
    //  Se mantiene abierta mientras conviva con la app nueva.
    //  Cuando migremos del todo, esto se puede cerrar/eliminar.
    // =========================================================
    match /participants/{id} {
      allow read, write: if true;
    }

    // =========================================================
    //  APP NUEVA (grupos con login)
    // =========================================================
    function signedIn() { return request.auth != null; }

    function groupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }
    function isMember(groupId) {
      return signedIn() && request.auth.uid in groupData(groupId).memberUids;
    }

    // --- Perfiles de usuario ---
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // --- Tarjetas públicas de invitación (solo el nombre, para la pantalla de "unirme") ---
    match /groupInvites/{groupId} {
      allow read: if signedIn();
      allow write: if signedIn() &&
                   request.auth.uid == groupData(groupId).ownerUid;
    }

    // --- Grupos ---
    match /groups/{groupId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;

      allow create: if signedIn()
                    && request.auth.uid == request.resource.data.ownerUid
                    && request.auth.uid in request.resource.data.memberUids;

      // Editar: cualquier miembro; o un usuario nuevo que se añade A SÍ MISMO (unirse por link).
      allow update: if signedIn() && (
        request.auth.uid in resource.data.memberUids
        || (
          !(request.auth.uid in resource.data.memberUids)
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
        )
      );

      allow delete: if signedIn() && request.auth.uid == resource.data.ownerUid;

      // --- Disponibilidad de cada miembro dentro del grupo ---
      match /members/{uid} {
        allow read: if isMember(groupId);
        // Solo editas TU propia disponibilidad.
        allow write: if signedIn() && request.auth.uid == uid;
      }
    }
  }
}
